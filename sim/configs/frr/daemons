# FRRouting daemons file — shared by every FRR node in the NETRA lab.
# Bind-mounted to /etc/frr/daemons. Enables exactly the daemons the reference
# topology needs: IS-IS (underlay IGP), OSPF (overlay/PE-CE + tunnels), LDP
# (LDP profile only), BGP (MP-BGP VPNv4), and the zebra/staticd core.
#
# SR-MPLS needs no separate daemon (label SIDs ride in IS-IS); for the LDP
# variant flip `ldpd=yes`.

zebra=yes
bgpd=yes
ospfd=yes
ospf6d=no
isisd=yes
ldpd=no          # set yes for the LDP underlay profile (configs/templates/ldp)
pimd=no
pim6d=no
nhrpd=no
eigrpd=no
babeld=no
sharpd=no
pbrd=no
bfdd=yes         # BFD for fast adjacency-down detection (scenario C precursor)
fabricd=no
vrrpd=no
pathd=no         # set yes if SR-TE explicit paths are exercised

# Options passed to the daemons; -A 127.0.0.1 binds the vty to localhost only.
zebra_options="  -A 127.0.0.1 -s 90000000"
bgpd_options="   -A 127.0.0.1"
ospfd_options="  -A 127.0.0.1"
isisd_options="  -A 127.0.0.1"
ldpd_options="   -A 127.0.0.1"
bfdd_options="   -A 127.0.0.1"
