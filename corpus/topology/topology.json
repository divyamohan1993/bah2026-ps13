    {"site": "hub1", "site_type": "hub", "description": "Hub aggregation site; scenario-A congestion target."},
    {"site": "br1", "site_type": "branch", "description": "Branch spoke 1."},
    {"site": "br2", "site_type": "branch", "description": "Branch spoke 2."},
    {"site": "br3", "site_type": "branch", "description": "Branch spoke 3; scenario-C tunnel-degradation target."},
    {"site": "core", "site_type": "core", "description": "MPLS provider core (IS-IS + SR-MPLS); scenario-C underlay."},
    {"site": "rr1", "site_type": "core", "description": "Route reflector site; scenario-B BGP-flap target."}
  ],
  "devices": [
