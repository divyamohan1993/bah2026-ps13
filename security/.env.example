# NETRA — offline-by-design environment variables (air-gap layer 6).
# ==================================================================
# Copy to `.env` next to the top-level docker-compose.yml. These switch off
# every known phone-home / telemetry / auto-update path in the stack so that
# even if a layer-1..5 control were misconfigured, the software still makes no
# outbound call (ARCHITECTURE.md §8 layer 6, research 07 §B6.6). `.env` itself
# is git-ignored; only this `.example` is committed.

# ---- HuggingFace / transformers: load from local snapshot only, no fetch ----
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
HF_HUB_DISABLE_TELEMETRY=1
HF_HUB_DISABLE_IMPLICIT_TOKEN=1
HF_DATASETS_OFFLINE=1

# ---- Generic "do not phone home" switches honoured by many tools ----
DO_NOT_TRACK=1
DISABLE_TELEMETRY=1
TELEMETRY_DISABLED=1

# ---- UI / dashboard frameworks ----
GRADIO_ANALYTICS_ENABLED=False
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false
GF_ANALYTICS_REPORTING_ENABLED=false
GF_ANALYTICS_CHECK_FOR_UPDATES=false
GF_ANALYTICS_CHECK_FOR_PLUGIN_UPDATES=false

# ---- Python / pip: never reach an index at runtime ----
PIP_NO_INDEX=1
PIP_DISABLE_PIP_VERSION_CHECK=1

# ---- llama.cpp / inference: no network features needed ----
LLAMA_NO_UPDATE_CHECK=1

# ---- Qdrant: disable anonymized usage reporting ----
QDRANT__TELEMETRY_DISABLED=true
